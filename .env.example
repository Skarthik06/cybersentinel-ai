# CyberSentinel AI — Environment Configuration
# Copy to .env and fill in your values

# ─────────────────────────────────────────
# LLM PROVIDER — Choose ONE provider
# ─────────────────────────────────────────
# Options: claude | openai | gemini
# Only set the API key for your chosen provider.
LLM_PROVIDER=claude

# ── Option 1: Anthropic Claude (default, recommended) ────────────────────────
# Get key: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Option 2: OpenAI GPT-4o ──────────────────────────────────────────────────
# Get key: https://platform.openai.com → API Keys
# Set LLM_PROVIDER=openai to activate
OPENAI_API_KEY=sk-your-openai-key-here

# ── Option 3: Google Gemini ───────────────────────────────────────────────────
# Get key: https://aistudio.google.com → Get API key
# Set LLM_PROVIDER=gemini to activate
GOOGLE_API_KEY=AIza-your-google-key-here

# ── Optional: Override default models per capability tier ────────────────────
# Leave blank to use the provider's smart defaults.
# Claude defaults:  primary=claude-opus-4-5 | fast=claude-haiku-4-5-20251001 | analysis=claude-sonnet-4-6
# OpenAI defaults:  primary=gpt-4o          | fast=gpt-4o-mini               | analysis=gpt-4o
# Gemini defaults:  primary=gemini-1.5-pro  | fast=gemini-1.5-flash          | analysis=gemini-1.5-pro
LLM_MODEL_PRIMARY=
LLM_MODEL_FAST=
LLM_MODEL_ANALYSIS=

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
POSTGRES_PASSWORD=sentinel_secure_2025_change_me
REDIS_PASSWORD=redis_secure_2025_change_me
CHROMA_TOKEN=cybersentinel-token-2025-change-me
JWT_SECRET=your-jwt-secret-minimum-32-chars-change-me

# ─────────────────────────────────────────
# THREAT INTELLIGENCE APIs (Optional but recommended)
# ─────────────────────────────────────────
NVD_API_KEY=                    # https://nvd.nist.gov/developers/request-an-api-key
ABUSEIPDB_KEY=                  # https://www.abuseipdb.com/api
OTX_API_KEY=                    # https://otx.alienvault.com/api
SHODAN_API_KEY=                 # https://developer.shodan.io

# ─────────────────────────────────────────
# NOTIFICATIONS
# ─────────────────────────────────────────
# Slack Bot API (required for all n8n workflow notifications)
# Create a Slack App at https://api.slack.com/apps → OAuth & Permissions → Bot Token Scopes: chat:write
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# Channel ID (not name) — right-click channel in Slack → View channel details → copy ID
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Deprecated — remove these if upgrading from v1.1
# SLACK_WEBHOOK=
# PAGERDUTY_KEY=

# ─────────────────────────────────────────
# DPI SENSOR
# ─────────────────────────────────────────
CAPTURE_INTERFACE=eth0           # Network interface to capture on
BPF_FILTER=ip                   # Berkeley Packet Filter expression

# ─────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────
GRAFANA_PASSWORD=admin2025_change_me

# ─────────────────────────────────────────
# RAG GOVERNANCE (all have safe defaults)
# ─────────────────────────────────────────

# Embedding model — MUST match what was used to create ChromaDB collections.
# Changing this after first run requires re-embedding all collections.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Max chars per embedded chunk (~225 tokens for all-MiniLM-L6-v2)
MAX_CHUNK_CHARS=900
CHUNK_OVERLAP_CHARS=100

# ChromaDB upsert batch size. Increase for high-RAM deployments (50→500).
EMBED_BATCH_SIZE=100

# Redis TTL for embedding cache (seconds). 0 = disabled.
# Prevents re-embedding unchanged RLM profiles — major CPU saving.
EMBED_CACHE_TTL_SEC=3600

# MITRE ATT&CK re-embed interval (days). 7 = at most weekly.
# MITRE updates ~2x/year — daily re-embedding wastes compute.
MITRE_REEMBED_INTERVAL_DAYS=7

# ChromaDB collection TTL eviction
PROFILE_TTL_DAYS=30     # Delete behavior profiles not updated in 30 days
CTI_TTL_DAYS=90         # Delete CTI reports older than 90 days

# RLM Engine thresholds (tunable without code changes)
RLM_ALPHA=0.1                    # EMA learning rate
RLM_ANOMALY_THRESHOLD=0.65       # Cosine similarity to emit anomaly alert
RLM_THREAT_MATCH_THRESHOLD=0.50  # Min similarity to attach threat metadata
RLM_MIN_OBSERVATIONS=20          # Min packets before scoring starts
RLM_CHROMA_N_RESULTS=3           # n_results for ChromaDB anomaly query
