FROM python:3.11-slim

WORKDIR /app

# Install all three LLM provider SDKs.
# Only the one matching LLM_PROVIDER will be used at runtime.
# anthropic, openai, and google-generativeai are all lightweight —
# installing all three adds ~50MB but enables zero-downtime provider switching.
RUN pip install --no-cache-dir \
    "numpy<2.0" \
    anthropic==0.34.2 \
    openai==1.35.0 \
    google-generativeai==0.7.0 \
    aiokafka==0.10.0 \
    chromadb==0.4.22 \
    asyncpg==0.29.0 \
    redis[asyncio]==5.0.1 \
    httpx==0.26.0

COPY src/agents ./src/agents
COPY src/core   ./src/core

CMD ["python", "-u", "src/agents/mcp_orchestrator.py"]
